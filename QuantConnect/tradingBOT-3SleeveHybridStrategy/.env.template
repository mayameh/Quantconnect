# Three-Sleeve Hybrid Alpaca bot
# Copy to .env on the VPS and fill in values. Do not commit real secrets.

APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_PAPER=true

BOT_LOG_DIR=~/trading/three-sleeve-hybrid/logs
BOT_STARTING_CAPITAL=100000
BOT_MIN_TRADE_NOTIONAL=25
BOT_MAX_GROSS_EXPOSURE=1.0

# Email alerts. Gmail app passwords work well here.
BOT_EMAIL_ENABLED=true
BOT_SMTP_SERVER=smtp.gmail.com
BOT_SMTP_PORT=587
BOT_EMAIL_USER=
BOT_EMAIL_PASS=
BOT_EMAIL_TO=

# Live S1 hedges. The original Lean algo used BRK.B/NEM live to avoid
# PRIIPs restrictions while still reading SPY/GLD as signals.
BOT_S1_MARKET_PROXY=BRK.B
BOT_S1_GOLD_PROXY=NEM

# Optional comma-separated overrides for the static Alpaca universes.
# Alpaca does not provide QuantConnect Morningstar fundamentals/universe
# selection, so these lists replace the QC fine-fundamental universe.
# BOT_S2_CANDIDATES=AAPL,MSFT,GOOGL,AMZN,META,BRK.B,JPM,V,MA,UNH
# BOT_S3_CANDIDATES=NVDA,AAPL,MSFT,AMZN,META,GOOGL,AVGO,TSLA,LLY,JPM
