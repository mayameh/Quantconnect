# ==============================================================================
# .env — IB Gateway + LEAN secrets (DO NOT COMMIT TO GIT)
# Copy this to /opt/lean-trading/.env and fill in your values
# ==============================================================================

# IB login credentials
IB_LOGIN_ID=
IB_PASSWORD=
IB_ACCOUNT=

# paper or live
IB_TRADING_MODE=paper

# 4001 for live, 4002 for paper
IB_PORT=4002

# Alpaca API credentials for external revenue-growth data
BOT_ALPACA_API_KEY=
BOT_ALPACA_API_SECRET=
# Optional endpoint override if your Alpaca plan/account uses a different path
# BOT_ALPACA_FINANCIALS_PATH=/v1beta1/fundamentals/{symbol}

# VNC password for debugging IB Gateway GUI
VNC_PASSWORD=headless

# LEAN Docker image tag
LEAN_TAG=latest
