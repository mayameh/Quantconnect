# ============================================================
#  EnhancedtradingBOTAlpaca — environment variables template
#  Copy this file to .env (or ~/trading/alpaca-bot/.env) and
#  fill in your values.  NEVER commit .env to git.
# ============================================================

# ── Alpaca API credentials ────────────────────────────────
# Both paper and live accounts use the same key format.
# Get them from https://app.alpaca.markets → API Keys
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Set to "true" for paper trading, "false" for live
APCA_API_PAPER=true

# ── Bot strategy/runtime ──────────────────────────────────
# TECH_MOMENTUM = weekly tech-universe 126-day momentum strategy
# HYBRID        = original multi-signal strategy path
BOT_STRATEGY_MODE=TECH_MOMENTUM
BOT_TRADING_STYLE=SWING

# Optional backtest/reporting fallback only. Live/paper uses Alpaca account equity.
# BOT_STARTING_CAPITAL=0

# ── Email alerts ──────────────────────────────────────────
BOT_EMAIL_USER=
BOT_EMAIL_PASS=
BOT_EMAIL_TO=

# ── Log directory ─────────────────────────────────────────
BOT_LOG_DIR=/opt/alpaca-bot/logs

# ── Optional overrides ────────────────────────────────────
# Alpaca fundamentals endpoint overrides
# BOT_FUNDAMENTALS_BASE_URL=https://data.alpaca.markets
# BOT_ALPACA_FINANCIALS_PATH=/v1beta1/fundamentals/{symbol}

# IEX Cloud token for live quote stream (live_feeds.py)
# Leave blank to disable the WebSocket quote feed
# IEX_TOKEN=
