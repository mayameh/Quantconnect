# ============================================================
#  EnhancedtradingBOTAlpaca — environment variables template
#  Copy this file to .env (or ~/trading/alpaca-bot/.env) and
#  fill in your values.  NEVER commit .env to git.
# ============================================================

# ── Alpaca API credentials ────────────────────────────────
# Both paper and live accounts use the same key format.
# Get them from https://app.alpaca.markets → API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Set to "true" for paper trading, "false" for live
ALPACA_PAPER=true

# ── Email alerts ──────────────────────────────────────────
BOT_EMAIL_USER=
BOT_EMAIL_PASS=
BOT_EMAIL_TO=

# ── Log directory ─────────────────────────────────────────
BOT_LOG_DIR=/opt/alpaca-bot/logs

# ── Optional overrides ────────────────────────────────────
# Alpaca data base URL (defaults to standard endpoint)
# BOT_ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# IEX Cloud token for live quote stream (live_feeds.py)
# Leave blank to disable the WebSocket quote feed
# IEX_TOKEN=
